# Porta em que o bridge escuta (liga em 0.0.0.0 para o celular na LAN alcançar).
PORT=8787
# Endereço onde o `opencode serve` está escutando.
OPENCODE_URL=http://127.0.0.1:4096
# Senha do servidor opencode (opcional) — se definida, o bridge envia Authorization: Basic.
OPENCODE_SERVER_PASSWORD=
# Usuário para a auth Basic do opencode (opcional, default "opencode").
OPENCODE_SERVER_USERNAME=opencode
# Provider do modelo no opencode (opcional) — só usado se OPENCODE_MODEL também estiver definido.
OPENCODE_PROVIDER=
# Modelo no opencode (opcional) — só usado se OPENCODE_PROVIDER também estiver definido.
OPENCODE_MODEL=
